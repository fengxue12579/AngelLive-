  运行时若该 override 文件存在则优先读取;两者都为空时 Bugsnag 静默跳过启动。
-->
<plist version="1.0">
<dict>
    <key>iOS</key>
    <string></string>
    <key>macOS</key>
    <string></string>
    <key>tvOS</key>
    <string></string>
</dict>
</plist>
